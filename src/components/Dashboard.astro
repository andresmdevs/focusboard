---
// Métricas rápidas por estado.
---
<section class="dashboard" aria-label="Resumen de tareas">
  <article class="metric-card"><span class="metric-label">Pendientes</span><strong id="metric-todo">0</strong></article>
  <article class="metric-card"><span class="metric-label">En progreso</span><strong id="metric-progress">0</strong></article>
  <article class="metric-card"><span class="metric-label">Por validar</span><strong id="metric-testing">0</strong></article>
  <article class="metric-card metric-card-success"><span class="metric-label">Completadas</span><strong id="metric-done">0</strong></article>
</section>
