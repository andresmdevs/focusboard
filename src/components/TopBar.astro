---
// Barra superior: marca, cambio de tema y botón de nueva tarea.
---
<header class="topbar">
  <a class="brand" href="#top" aria-label="Focusboard, inicio">
    <span class="brand-mark" aria-hidden="true">✓</span>
    <span>focusboard</span>
  </a>
  <div class="topbar-actions">
    <!-- Enlace deliberadamente invisible (opacity:0, sin foco por teclado, oculto
         a lectores de pantalla): sigue siendo clicable en el mismo lugar de
         siempre para quien sepa que está aquí, pero nadie mirando la pantalla
         lo ve ni lo tabula por accidente. -->
    <a class="secret-link" href="/empleo" aria-hidden="true" tabindex="-1"></a>
    <button class="icon-button" id="theme-toggle" type="button" aria-label="Cambiar tema" title="Cambiar tema">
      <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.36-6.36-1.42 1.42M7.05 16.95l-1.42 1.42m12.73 0-1.42-1.42M7.05 7.05 5.64 5.64M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Z" /></svg>
    </button>
    <button class="primary-button" id="open-task-form" type="button">
      <span aria-hidden="true">+</span> Nueva tarea
    </button>
  </div>
</header>
