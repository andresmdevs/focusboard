---
// Búsqueda y filtros del tablero.
---
<section class="board-controls" aria-label="Filtros del tablero">
  <label class="search-field">
    <svg aria-hidden="true" viewBox="0 0 24 24"><path d="m21 21-4.35-4.35M19 11a8 8 0 1 1-16 0 8 8 0 0 1 16 0Z" /></svg>
    <input id="search-input" type="search" placeholder="Buscar tareas o etiquetas" autocomplete="off" />
  </label>
  <label class="filter-field">
    <span class="sr-only">Filtrar por prioridad</span>
    <select id="priority-filter">
      <option value="all">Todas las prioridades</option>
      <option value="high">Alta prioridad</option>
      <option value="medium">Prioridad media</option>
      <option value="low">Prioridad baja</option>
    </select>
  </label>
  <button class="text-button" id="clear-filters" type="button">Limpiar filtros</button>
</section>
