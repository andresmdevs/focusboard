---
// Radar de empleo: top diario de ofertas publicado por job-radar en
// Realtime Database (nodo jobRadar). Solo lectura desde el cliente.
import RadarLayout from "../layouts/RadarLayout.astro";
---

<RadarLayout
  title="Radar de empleo · focusboard"
  description="Top diario de ofertas laborales remotas ajustadas al perfil."
>
  <div class="app-shell" id="top">
    <header class="topbar">
      <a class="brand" href="/" aria-label="Volver al tablero">
        <span class="brand-mark" aria-hidden="true">✓</span>
        <span>focusboard</span>
      </a>
      <div class="topbar-actions">
        <a class="secondary-button" href="/">Tablero</a>
        <button class="secondary-button" id="radar-logout" type="button" hidden>Salir</button>
        <button class="icon-button" id="radar-theme-toggle" type="button" aria-label="Cambiar tema" title="Cambiar tema">
          <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.36-6.36-1.42 1.42M7.05 16.95l-1.42 1.42m12.73 0-1.42-1.42M7.05 7.05 5.64 5.64M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Z" /></svg>
        </button>
      </div>
    </header>

    <section class="radar-gate" id="radar-gate">
      <div class="gate-card">
        <p class="eyebrow">ACCESO PRIVADO</p>
        <h2>Radar de empleo</h2>
        <p class="gate-copy" id="radar-gate-copy">Verificando sesión…</p>

        <button class="primary-button" id="radar-login" type="button" hidden>
          Iniciar sesión con Google
        </button>

        <button class="text-button gate-toggle" id="radar-gate-show-phone" type="button" hidden>
          O inicia sesión con tu número de teléfono
        </button>

        <form class="gate-phone-form" id="radar-phone-form" hidden>
          <label class="sr-only" for="radar-phone-input">Número de teléfono</label>
          <input
            id="radar-phone-input"
            type="tel"
            inputmode="tel"
            autocomplete="tel"
            placeholder="+57 300 000 0000"
          />
          <button class="primary-button" id="radar-phone-send" type="submit">
            Enviar código
          </button>

          <div class="gate-phone-code" id="radar-phone-code-group" hidden>
            <label class="sr-only" for="radar-phone-code">Código recibido por SMS</label>
            <input
              id="radar-phone-code"
              type="text"
              inputmode="numeric"
              autocomplete="one-time-code"
              placeholder="Código de 6 dígitos"
              maxlength="6"
            />
            <button class="primary-button" id="radar-phone-verify" type="button">
              Verificar código
            </button>
          </div>

          <button class="text-button gate-toggle" id="radar-gate-show-google" type="button" hidden>
            ← Volver a Google
          </button>
        </form>

        <div id="radar-recaptcha-container"></div>
      </div>
    </section>

    <div id="radar-content" hidden>
    <section class="hero radar-hero">
      <div>
        <p class="eyebrow">RADAR DE EMPLEO</p>
        <h1>Top del día para tu perfil</h1>
        <p class="hero-copy">
          Ofertas 100% remotas de QA Automation y Full Stack en Colombia, LatAm y
          España, filtradas por tus criterios y actualizadas cada mañana.
        </p>
      </div>
      <div class="focus-card">
        <p>Última corrida</p>
        <strong id="radar-updated">Cargando…</strong>
        <span id="radar-floor"></span>
        <button class="refresh-btn" id="radar-refresh" type="button">
          ⟳ Actualizar ahora
        </button>
        <span id="radar-refresh-status" class="refresh-status" hidden></span>
      </div>
    </section>

    <section class="dashboard radar-metrics" aria-label="Métricas del radar">
      <article class="metric-card">
        <span class="metric-label">Ofertas encontradas</span>
        <strong id="radar-found">—</strong>
      </article>
      <article class="metric-card metric-card-success">
        <span class="metric-label">Nuevas hoy</span>
        <strong id="radar-new">—</strong>
      </article>
      <article class="metric-card">
        <span class="metric-label">Descartadas por filtros</span>
        <strong id="radar-discarded">—</strong>
      </article>
      <article class="metric-card">
        <span class="metric-label">Fuentes activas</span>
        <strong id="radar-sources">—</strong>
      </article>
    </section>

    <details class="settings-panel" id="radar-settings">
      <summary>⚙ Parámetros de búsqueda</summary>
      <div class="settings-body">
        <p class="settings-hint">
          Los cambios se aplican en la próxima corrida del radar (automática o vía
          "Actualizar ahora"), no reordenan la tabla de abajo al instante.
        </p>

        <div class="settings-grid">
          <div class="settings-row">
            <label for="settings-language">Idioma de las ofertas</label>
            <select id="settings-language">
              <option value="any">Cualquiera</option>
              <option value="es">Solo español</option>
              <option value="en">Solo inglés</option>
            </select>
          </div>
          <div class="settings-row">
            <label for="settings-salary">Piso salarial (COP/mes)</label>
            <input id="settings-salary" type="number" step="500000" min="0" />
          </div>
        </div>

        <div class="settings-row settings-row-full">
          <label>Fuentes activas</label>
          <div class="settings-checkboxes" id="settings-sources"></div>
        </div>

        <div class="settings-row settings-row-full">
          <label>Consultas de búsqueda personalizadas</label>
          <div class="settings-tags" id="settings-queries"></div>
          <div class="settings-add-row">
            <input id="settings-query-input" type="text" placeholder="ej. platform engineer" />
            <button class="secondary-button" id="settings-query-add" type="button">Agregar</button>
          </div>
        </div>

        <div class="settings-row settings-row-full">
          <label>
            Solicitar un portal nuevo — no es scraping automático: cada portal
            requiere revisión manual antes de integrarse (como Computrabajo o
            elempleo.com), esto solo deja tu solicitud anotada.
          </label>
          <div class="settings-tags" id="settings-portals"></div>
          <div class="settings-add-row">
            <input id="settings-portal-input" type="text" placeholder="Nombre o URL, ej. InfoJobs España" />
            <button class="secondary-button" id="settings-portal-add" type="button">Solicitar</button>
          </div>
        </div>

        <div class="settings-footer">
          <button class="primary-button" id="settings-save" type="button">Guardar parámetros</button>
          <span id="settings-status" class="settings-status" aria-live="polite"></span>
        </div>
      </div>
    </details>

    <div class="board-controls radar-controls">
      <label class="search-field">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="m21 21-4.3-4.3M11 19a8 8 0 1 1 0-16 8 8 0 0 1 0 16Z" /></svg>
        <input id="radar-search" type="search" placeholder="Filtrar por rol o empresa" autocomplete="off" />
      </label>
      <label class="filter-field">
        <span class="sr-only">Fuente</span>
        <select id="radar-source-filter"><option value="">Todas las fuentes</option></select>
      </label>
      <label class="filter-field">
        <span class="sr-only">Score mínimo</span>
        <select id="radar-score-filter">
          <option value="0">Cualquier score</option>
          <option value="60">Score 60+</option>
          <option value="75">Score 75+</option>
        </select>
      </label>
      <label class="filter-field">
        <span class="sr-only">Día</span>
        <select id="radar-run-filter"><option value="latest">Hoy (última corrida)</option></select>
      </label>
    </div>

    <section id="radar-list" class="radar-list" aria-live="polite"></section>
    <p id="radar-empty" class="radar-empty" hidden>
      Aún no hay datos del radar. Corre <code>job-radar</code> con
      <code>--publish</code> o espera la próxima corrida automática.
    </p>
    </div>
  </div>
</RadarLayout>

<style is:global>
  /* is:global porque las tarjetas se inyectan con innerHTML y no reciben el
     atributo de scope de Astro; los selectores van prefijados para no chocar. */
  .radar-gate { display: grid; place-items: center; min-height: 62vh; padding: 40px 0; }
  .gate-card { max-width: 430px; padding: 34px 32px; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); box-shadow: var(--shadow); text-align: center; }
  .gate-card h2 { margin: 0 0 10px; font-family: Fraunces, Georgia, serif; font-size: 1.9rem; font-weight: 600; letter-spacing: -.04em; }
  .gate-copy { margin-bottom: 20px; color: var(--muted); font-size: .93rem; line-height: 1.5; }
  .gate-copy.is-error { color: var(--red); }
  #radar-login { width: 100%; }
  .gate-toggle { display: block; width: 100%; margin-top: 12px; text-align: center; }
  .gate-phone-form { display: grid; gap: 10px; margin-top: 14px; }
  .gate-phone-form input { width: 100%; height: 42px; padding: 0 13px; border: 1px solid var(--line); border-radius: 10px; background: var(--surface); color: var(--text); text-align: center; font-size: .95rem; }
  .gate-phone-code { display: grid; gap: 10px; }
  #radar-recaptcha-container { display: flex; justify-content: center; margin-top: 10px; }

  .radar-hero { padding-bottom: 28px; }
  .radar-metrics { margin-bottom: 6px; }
  .radar-controls { flex-wrap: wrap; }
  .radar-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(305px, 1fr)); gap: 14px; padding-top: 6px; }
  .radar-empty { padding: 40px 0; color: var(--muted); text-align: center; }

  .job-card { display: flex; flex-direction: column; gap: 9px; padding: 16px; background: var(--surface); border: 1px solid color-mix(in srgb, var(--line) 85%, transparent); border-radius: 12px; box-shadow: 0 3px 10px rgba(25, 38, 32, .035); transition: transform .16s ease, box-shadow .16s ease; }
  .job-card:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
  .job-card-top { display: flex; align-items: center; gap: 7px; }
  .score-badge { padding: 3px 8px; border-radius: 999px; font-family: "DM Mono", monospace; font-size: .68rem; font-weight: 500; }
  .score-high { background: var(--accent-soft); color: var(--accent-dark); }
  .score-mid { background: var(--yellow-soft); color: #996608; }
  [data-theme="dark"] .score-mid { color: var(--yellow); }
  .score-low { background: var(--surface-muted); color: var(--muted); }
  .source-tag { padding: 3px 7px; border-radius: 5px; background: var(--surface-muted); color: var(--muted); font-size: .68rem; }
  .new-dot { margin-left: auto; padding: 3px 7px; border-radius: 999px; background: var(--purple-soft); color: var(--purple); font-size: .66rem; font-weight: 600; }
  .job-card h3 { margin: 0; font-size: .98rem; line-height: 1.35; letter-spacing: -.015em; }
  .job-card h3 a { color: var(--text); text-decoration: none; }
  .job-card h3 a:hover { color: var(--accent); text-decoration: underline; }
  .job-meta { margin: 0; color: var(--muted); font-size: .82rem; line-height: 1.4; }
  .job-footer { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-top: auto; padding-top: 4px; }
  .salary-chip { padding: 3px 8px; border-radius: 6px; background: var(--surface-muted); color: var(--muted); font-family: "DM Mono", monospace; font-size: .72rem; }
  .salary-ok { background: var(--accent-soft); color: var(--accent-dark); font-weight: 500; }
  .job-date { color: var(--muted); font-size: .74rem; }
  .cv-btn { margin-top: 4px; padding: 8px 10px; border: 1px solid var(--line); border-radius: 9px; background: transparent; color: var(--accent); font-size: .8rem; font-weight: 600; transition: background .15s ease, border-color .15s ease; }
  .cv-btn:hover { background: var(--accent-soft); border-color: var(--accent); }
  .cv-btn:disabled { opacity: .75; cursor: default; }
  .refresh-btn { display: block; margin-top: 12px; padding: 8px 12px; border: 1px solid rgba(255,255,255,.35); border-radius: 9px; background: rgba(255,255,255,.12); color: #effaf6; font-size: .82rem; font-weight: 600; }
  .refresh-btn:hover { background: rgba(255,255,255,.22); }
  .refresh-btn:disabled { opacity: .6; cursor: default; }
  .refresh-status { display: block; margin-top: 7px; font-size: .74rem; color: #d9f0e7; }
  .refresh-status.is-warning { color: #ffe1b3; font-weight: 600; }

  .settings-panel { margin: 6px 0 4px; background: var(--surface); border: 1px solid var(--line); border-radius: 13px; }
  .settings-panel summary { padding: 14px 18px; font-weight: 600; font-size: .92rem; cursor: pointer; list-style: none; }
  .settings-panel summary::-webkit-details-marker { display: none; }
  .settings-panel[open] summary { border-bottom: 1px solid var(--line); }
  .settings-body { padding: 18px; display: grid; gap: 16px; }
  .settings-hint { margin: 0; color: var(--muted); font-size: .8rem; line-height: 1.4; }
  .settings-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
  .settings-row { display: grid; gap: 6px; }
  .settings-row label { font-size: .82rem; color: var(--muted); font-weight: 600; }
  .settings-row select, .settings-row input[type="number"] { height: 40px; padding: 0 12px; border: 1px solid var(--line); border-radius: 9px; background: var(--surface); color: var(--text); font-size: .9rem; }
  .settings-checkboxes { display: flex; flex-wrap: wrap; gap: 8px; }
  .settings-check { display: inline-flex; align-items: center; gap: 6px; padding: 7px 11px; border: 1px solid var(--line); border-radius: 999px; font-size: .82rem; cursor: pointer; user-select: none; }
  .settings-check input { accent-color: var(--accent); }
  .settings-tags { display: flex; flex-wrap: wrap; gap: 8px; min-height: 4px; }
  .settings-tag { display: inline-flex; align-items: center; gap: 6px; padding: 5px 10px; background: var(--surface-muted); border-radius: 999px; font-size: .78rem; }
  .settings-tag button { border: 0; background: transparent; color: var(--muted); font-size: 1rem; line-height: 1; cursor: pointer; padding: 0; }
  .settings-tag button:hover { color: var(--red); }
  .settings-add-row { display: flex; gap: 8px; }
  .settings-add-row input { flex: 1; height: 38px; padding: 0 12px; border: 1px solid var(--line); border-radius: 9px; background: var(--surface); color: var(--text); font-size: .86rem; }
  .settings-footer { display: flex; align-items: center; gap: 12px; }
  .settings-status { font-size: .8rem; color: var(--muted); }
  .settings-status.is-error { color: var(--red); }
  .settings-status.is-ok { color: var(--accent); }
</style>

<script>
  import { db } from "../scripts/firebase.js";
  import { ref, onValue, set } from "firebase/database";
  import {
    auth, isAllowed, watchSession, login, logout,
    consumeRedirectResult, sendPhoneCode, confirmPhoneCode,
  } from "../scripts/auth.js";
  import { registerServiceWorker } from "../scripts/sw.js";

  registerServiceWorker();

  const THEME_KEY = "focusboard.theme.v1";
  document.querySelector("#radar-theme-toggle").addEventListener("click", () => {
    const theme = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = theme;
    localStorage.setItem(THEME_KEY, theme);
  });

  const els = {
    updated: document.querySelector("#radar-updated"),
    floor: document.querySelector("#radar-floor"),
    found: document.querySelector("#radar-found"),
    newCount: document.querySelector("#radar-new"),
    discarded: document.querySelector("#radar-discarded"),
    sources: document.querySelector("#radar-sources"),
    search: document.querySelector("#radar-search"),
    sourceFilter: document.querySelector("#radar-source-filter"),
    scoreFilter: document.querySelector("#radar-score-filter"),
    runFilter: document.querySelector("#radar-run-filter"),
    list: document.querySelector("#radar-list"),
    empty: document.querySelector("#radar-empty"),
    refreshBtn: document.querySelector("#radar-refresh"),
    refreshStatus: document.querySelector("#radar-refresh-status"),
    gate: document.querySelector("#radar-gate"),
    gateCopy: document.querySelector("#radar-gate-copy"),
    loginBtn: document.querySelector("#radar-login"),
    logoutBtn: document.querySelector("#radar-logout"),
    content: document.querySelector("#radar-content"),
    showPhoneBtn: document.querySelector("#radar-gate-show-phone"),
    showGoogleBtn: document.querySelector("#radar-gate-show-google"),
    phoneForm: document.querySelector("#radar-phone-form"),
    phoneInput: document.querySelector("#radar-phone-input"),
    phoneSendBtn: document.querySelector("#radar-phone-send"),
    phoneCodeGroup: document.querySelector("#radar-phone-code-group"),
    phoneCodeInput: document.querySelector("#radar-phone-code"),
    phoneVerifyBtn: document.querySelector("#radar-phone-verify"),
    settingsLanguage: document.querySelector("#settings-language"),
    settingsSalary: document.querySelector("#settings-salary"),
    settingsSources: document.querySelector("#settings-sources"),
    settingsQueries: document.querySelector("#settings-queries"),
    settingsQueryInput: document.querySelector("#settings-query-input"),
    settingsQueryAdd: document.querySelector("#settings-query-add"),
    settingsPortals: document.querySelector("#settings-portals"),
    settingsPortalInput: document.querySelector("#settings-portal-input"),
    settingsPortalAdd: document.querySelector("#settings-portal-add"),
    settingsSave: document.querySelector("#settings-save"),
    settingsStatus: document.querySelector("#settings-status"),
  };

  let radar = null; // nodo jobRadar completo: { latest, runs, settings, refresh }
  let visibleJobs = []; // ofertas actualmente renderizadas (para el botón de CV)

  // Servicio job-radar en Render (capa gratuita). Vacío = solo watcher local.
  // Tras desplegar en Render, pega aquí la URL, p. ej. "https://job-radar.onrender.com".
  // El botón escribe la solicitud en Firebase y hace ping a este endpoint para
  // despertar el servicio dormido (cold start ~50s); el resto lo maneja Firebase.
  const REFRESH_ENDPOINT = "";

  // --- Panel de parámetros --------------------------------------------------
  // Fuentes que job-radar tiene registradas (jobradar/sources/*.py). Si algún
  // día se agrega una nueva fuente ahí, añadirla también aquí para que el
  // panel la ofrezca como opción.
  const KNOWN_SOURCES = [
    { id: "linkedin", label: "LinkedIn" },
    { id: "computrabajo", label: "Computrabajo (Colombia)" },
    { id: "elempleo", label: "elempleo.com (Colombia)" },
    { id: "getonbrd", label: "GetOnBoard (LatAm)" },
    { id: "freehire", label: "Freehire (LatAm + España)" },
  ];
  // Listas editables en memoria; solo se escriben a Firebase al pulsar
  // "Guardar parámetros" (evita escrituras parciales mientras se editan).
  let draftQueries = [];
  let draftPortalRequests = [];
  let settingsHydrated = false; // evita pisar lo que el usuario está editando

  const fmtDate = (iso) =>
    new Intl.DateTimeFormat("es-CO", { day: "numeric", month: "short", hour: "2-digit", minute: "2-digit" })
      .format(new Date(iso));

  const fmtDay = (day) =>
    new Intl.DateTimeFormat("es-CO", { weekday: "short", day: "numeric", month: "short" })
      .format(new Date(`${day}T12:00:00`));

  function currentRun() {
    if (!radar) return null;
    const key = els.runFilter.value;
    return key === "latest" ? radar.latest : radar.runs?.[key] || radar.latest;
  }

  function salaryLabel(job) {
    if (job.salaryCop) {
      const m = (job.salaryCop / 1e6).toFixed(1).replace(".", ",");
      return `${m}M COP${job.currency && job.currency !== "COP" ? ` · ${job.currency}` : ""}`;
    }
    return job.salaryText || "Salario s/d";
  }

  function hydrateControls(run) {
    const sources = [...new Set((run.jobs || []).map((j) => j.source))].sort();
    const selected = els.sourceFilter.value;
    els.sourceFilter.length = 1;
    for (const s of sources) els.sourceFilter.add(new Option(s, s));
    els.sourceFilter.value = sources.includes(selected) ? selected : "";

    const runKeys = Object.keys(radar.runs || {}).sort().reverse();
    const selectedRun = els.runFilter.value;
    els.runFilter.length = 1;
    for (const k of runKeys) els.runFilter.add(new Option(fmtDay(k), k));
    if ([...els.runFilter.options].some((o) => o.value === selectedRun)) {
      els.runFilter.value = selectedRun;
    }
  }

  // --- Panel de parámetros ---------------------------------------------------

  function renderTagList(container, items, onRemove) {
    container.innerHTML = items
      .map((text, idx) => `
        <span class="settings-tag">
          ${text}
          <button type="button" data-idx="${idx}" aria-label="Quitar">×</button>
        </span>`)
      .join("");
    container.querySelectorAll("button").forEach((btn) =>
      btn.addEventListener("click", () => onRemove(Number(btn.dataset.idx)))
    );
  }

  function renderQueryTags() {
    renderTagList(els.settingsQueries, draftQueries, (idx) => {
      draftQueries.splice(idx, 1);
      renderQueryTags();
    });
  }

  function renderPortalTags() {
    renderTagList(els.settingsPortals, draftPortalRequests, (idx) => {
      draftPortalRequests.splice(idx, 1);
      renderPortalTags();
    });
  }

  // Puebla el formulario desde jobRadar/settings. Solo la primera vez que
  // llegan datos (settingsHydrated) - así no se pisa lo que el usuario está
  // escribiendo si Firebase reenvía el mismo nodo mientras edita.
  function hydrateSettingsForm(settings) {
    if (settingsHydrated) return;
    settingsHydrated = true;
    const s = settings || {};

    els.settingsLanguage.value = s.language || "any";
    els.settingsSalary.value = s.salaryFloorCop || 7000000;

    const enabled = new Set(s.enabledSources?.length ? s.enabledSources : KNOWN_SOURCES.map((k) => k.id));
    els.settingsSources.innerHTML = KNOWN_SOURCES.map(({ id, label }) => `
      <label class="settings-check">
        <input type="checkbox" value="${id}" ${enabled.has(id) ? "checked" : ""} />
        ${label}
      </label>`).join("");

    draftQueries = [...(s.customQueries || [])];
    draftPortalRequests = [...(s.portalRequests || [])];
    renderQueryTags();
    renderPortalTags();
  }

  els.settingsQueryAdd.addEventListener("click", () => {
    const value = els.settingsQueryInput.value.trim();
    if (!value || draftQueries.includes(value)) return;
    draftQueries.push(value);
    els.settingsQueryInput.value = "";
    renderQueryTags();
  });
  els.settingsQueryInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") { e.preventDefault(); els.settingsQueryAdd.click(); }
  });

  els.settingsPortalAdd.addEventListener("click", () => {
    const value = els.settingsPortalInput.value.trim();
    if (!value || draftPortalRequests.includes(value)) return;
    draftPortalRequests.push(value);
    els.settingsPortalInput.value = "";
    renderPortalTags();
  });
  els.settingsPortalInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") { e.preventDefault(); els.settingsPortalAdd.click(); }
  });

  els.settingsSave.addEventListener("click", async () => {
    const enabledSources = [...els.settingsSources.querySelectorAll("input:checked")]
      .map((cb) => cb.value);
    if (!enabledSources.length) {
      els.settingsStatus.textContent = "Activa al menos una fuente.";
      els.settingsStatus.className = "settings-status is-error";
      return;
    }
    const payload = {
      language: els.settingsLanguage.value,
      salaryFloorCop: Number(els.settingsSalary.value) || 7000000,
      enabledSources,
      customQueries: draftQueries,
      portalRequests: draftPortalRequests,
      updatedAt: new Date().toISOString(),
    };
    els.settingsSave.disabled = true;
    els.settingsStatus.textContent = "Guardando…";
    els.settingsStatus.className = "settings-status";
    try {
      await set(ref(db, "jobRadar/settings"), payload);
      els.settingsStatus.textContent = "Guardado — se aplica en la próxima corrida.";
      els.settingsStatus.className = "settings-status is-ok";
    } catch (err) {
      console.error("Error guardando parámetros:", err);
      els.settingsStatus.textContent = "No se pudo guardar. Intenta de nuevo.";
      els.settingsStatus.className = "settings-status is-error";
    } finally {
      els.settingsSave.disabled = false;
    }
  });

  function render() {
    const run = currentRun();
    if (!run || !run.jobs?.length) {
      els.list.innerHTML = "";
      els.empty.hidden = false;
      els.updated.textContent = "Sin datos";
      return;
    }
    els.empty.hidden = true;

    els.updated.textContent = fmtDate(run.updated);
    els.floor.textContent = `Piso salarial: ${(run.floorCop / 1e6).toFixed(1).replace(".", ",")}M COP/mes`;
    els.found.textContent = run.stats?.found ?? "—";
    els.newCount.textContent = run.stats?.new ?? "—";
    els.discarded.textContent = run.stats?.discarded ?? "—";
    const srcStats = run.stats?.sources || {};
    els.sources.textContent = `${Object.values(srcStats).filter((n) => n > 0).length}/${Object.keys(srcStats).length || "—"}`;

    const text = els.search.value.trim().toLowerCase();
    const minScore = Number(els.scoreFilter.value);
    const source = els.sourceFilter.value;

    const jobs = (run.jobs || []).filter((j) =>
      j.score >= minScore &&
      (!source || j.source === source) &&
      (!text || `${j.title} ${j.company}`.toLowerCase().includes(text))
    );
    visibleJobs = jobs;

    els.list.innerHTML = jobs
      .map((j, idx) => {
        const band = j.score >= 75 ? "score-high" : j.score >= 60 ? "score-mid" : "score-low";
        const salaryClass = j.salaryCop ? "salary-chip salary-ok" : "salary-chip";
        return `
        <article class="job-card">
          <div class="job-card-top">
            <span class="score-badge ${band}">${j.score} pts</span>
            <span class="source-tag">${j.source}</span>
            ${j.isNew ? '<span class="new-dot">Nueva</span>' : ""}
          </div>
          <h3><a href="${j.url}" target="_blank" rel="noopener noreferrer">${j.title}</a></h3>
          <p class="job-meta">${j.company}${j.location ? ` · ${j.location}` : ""}</p>
          <div class="job-footer">
            <span class="${salaryClass}">${salaryLabel(j)}</span>
            <span class="job-date">${j.datePosted || ""}</span>
          </div>
          <button class="cv-btn" type="button" data-cv-idx="${idx}">
            Generar CV a medida (PDF)
          </button>
        </article>`;
      })
      .join("");

    if (!jobs.length) {
      els.list.innerHTML = `<p class="radar-empty">Nada coincide con los filtros.</p>`;
    }
  }

  for (const el of [els.search, els.sourceFilter, els.scoreFilter, els.runFilter]) {
    el.addEventListener("input", render);
  }

  // Botón "Actualizar ahora": escribe una solicitud en RTDB; el watcher local
  // de job-radar (`python -m jobradar --watch`) la ejecuta y publica. El estado
  // llega en tiempo real por la misma suscripción onValue.
  // Vigilante de solicitudes sin respuesta: si nadie procesa el pedido (el
  // watcher local o el servicio en Render no están encendidos), el botón se
  // quedaría deshabilitado para siempre sin explicación. WATCHDOG_MS es el
  // tiempo máximo de espera antes de avisar y liberar el botón.
  const WATCHDOG_MS = 90_000;
  let refreshWatchdog = null;
  let refreshTicker = null;
  let refreshStartedAt = null;

  function clearRefreshTimers() {
    if (refreshWatchdog) { clearTimeout(refreshWatchdog); refreshWatchdog = null; }
    if (refreshTicker) { clearInterval(refreshTicker); refreshTicker = null; }
  }

  els.refreshBtn.addEventListener("click", async () => {
    els.refreshBtn.disabled = true;
    clearRefreshTimers();
    refreshStartedAt = Date.now();
    refreshWatchdog = setTimeout(() => {
      showRefreshStatus(
        "El radar no respondió. Verifica que el servicio esté encendido " +
        "(watcher local o Render) e inténtalo de nuevo.",
        true
      );
      els.refreshBtn.disabled = false;
      refreshWatchdog = null;
    }, WATCHDOG_MS);
    try {
      await set(ref(db, "jobRadar/refresh/request"), {
        at: new Date().toISOString(),
        by: "web",
      });
      // Despierta el servicio de Render si está configurado (fire-and-forget:
      // el cold start tarda ~50s y el progreso llega por la suscripción a status).
      if (REFRESH_ENDPOINT) {
        fetch(`${REFRESH_ENDPOINT}/refresh`, { method: "POST" }).catch(() => {});
      }
      showRefreshStatus("Solicitud enviada — iniciando búsqueda…");
    } catch (err) {
      console.error("Error solicitando actualización:", err);
      showRefreshStatus("No se pudo enviar la solicitud.", true);
      els.refreshBtn.disabled = false;
      clearRefreshTimers();
    }
  });

  function showRefreshStatus(text, isWarning = false) {
    els.refreshStatus.textContent = text;
    els.refreshStatus.hidden = !text;
    els.refreshStatus.classList.toggle("is-warning", isWarning);
  }

  function renderRefresh() {
    const refresh = radar?.refresh || {};
    const state = refresh.status?.state;
    const pending = Boolean(refresh.request);
    if (state === "running") {
      els.refreshBtn.disabled = true;
      // Confirmado que un procesador real está trabajando: ya no hace falta
      // el vigilante de "no respondió", solo el contador de tiempo.
      if (refreshWatchdog) { clearTimeout(refreshWatchdog); refreshWatchdog = null; }
      if (!refreshTicker) {
        if (!refreshStartedAt) refreshStartedAt = Date.now();
        const tick = () => {
          const secs = Math.round((Date.now() - refreshStartedAt) / 1000);
          showRefreshStatus(`Buscando ofertas en vivo… (${secs}s)`);
        };
        tick();
        refreshTicker = setInterval(tick, 1000);
      }
    } else if (pending) {
      els.refreshBtn.disabled = true;
      showRefreshStatus("Solicitud en cola — iniciando el radar…");
    } else if (state === "error") {
      clearRefreshTimers();
      els.refreshBtn.disabled = false;
      showRefreshStatus(`Error en la última corrida: ${refresh.status?.message || "?"}`, true);
    } else if (state === "done" && refresh.status?.message) {
      clearRefreshTimers();
      els.refreshBtn.disabled = false;
      showRefreshStatus(refresh.status.message);
    } else {
      clearRefreshTimers();
      els.refreshBtn.disabled = false;
      showRefreshStatus("");
    }
  }

  // Generación de CV a medida: import dinámico para no cargar pdfmake (~1 MB)
  // hasta el primer clic.
  els.list.addEventListener("click", async (event) => {
    const btn = event.target.closest(".cv-btn");
    if (!btn) return;
    const job = visibleJobs[Number(btn.dataset.cvIdx)];
    if (!job) return;
    const original = btn.textContent;
    btn.disabled = true;
    btn.textContent = "Generando…";
    try {
      const { generateCv } = await import("../scripts/cvGenerator.js");
      const filename = generateCv(job);
      btn.textContent = `Descargado: ${filename}`;
      setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 3500);
    } catch (err) {
      console.error("Error generando CV:", err);
      btn.textContent = "Error al generar — reintentar";
      btn.disabled = false;
    }
  });

  // --- Sesión --------------------------------------------------------------
  // Los datos del radar solo se leen tras iniciar sesión con la cuenta
  // autorizada; las reglas de Realtime Database lo exigen del lado servidor.
  let unsubscribeRadar = null;

  function subscribeRadar() {
    return onValue(
      ref(db, "jobRadar"),
      (snapshot) => {
        radar = snapshot.val();
        if (radar?.latest) hydrateControls(currentRun() || radar.latest);
        hydrateSettingsForm(radar?.settings);
        render();
        renderRefresh();
      },
      (err) => {
        console.error("Error leyendo el radar:", err);
        els.updated.textContent =
          err.code === "PERMISSION_DENIED" ? "Sin permisos" : "Sin conexión";
        els.empty.hidden = false;
      }
    );
  }

  function showGate(message, isError = false) {
    els.gate.hidden = false;
    els.content.hidden = true;
    els.logoutBtn.hidden = true;
    els.gateCopy.textContent = message;
    els.gateCopy.classList.toggle("is-error", isError);
  }

  /** Muestra ambas opciones de login (Google + toggle a teléfono), respetando
   * cuál de los dos formularios está abierto en este momento. */
  function showLoginOptions() {
    els.loginBtn.hidden = false;
    if (els.phoneForm.hidden) els.showPhoneBtn.hidden = false;
  }

  // login() navega a Google (signInWithRedirect); si falla ANTES de salir de
  // la página (config inválida, etc.) cae aquí. El resultado del regreso se
  // procesa más abajo con consumeRedirectResult().
  els.loginBtn.addEventListener("click", async () => {
    els.loginBtn.disabled = true;
    showGate("Redirigiendo a Google…");
    try {
      await login();
    } catch (err) {
      console.error("Error al iniciar sesión:", err);
      showGate(`No se pudo iniciar sesión (${err?.code || "error desconocido"}).`, true);
      showLoginOptions();
      els.loginBtn.disabled = false;
    }
  });

  els.logoutBtn.addEventListener("click", () => logout());

  // --- Login por teléfono (alternativa a Google) ----------------------------
  // Respaldo cuando Google falla en algún dispositivo (redirect bloqueado,
  // almacenamiento restringido en Safari privado, etc.) - no depende de
  // redirects entre dominios, solo de un reCAPTCHA invisible + SMS.
  let confirmationResult = null;

  els.showPhoneBtn.addEventListener("click", () => {
    els.loginBtn.hidden = true;
    els.showPhoneBtn.hidden = true;
    els.phoneForm.hidden = false;
    els.showGoogleBtn.hidden = false;
    els.phoneInput.focus();
  });

  els.showGoogleBtn.addEventListener("click", () => {
    els.phoneForm.hidden = true;
    els.phoneCodeGroup.hidden = true;
    els.phoneInput.value = "";
    els.phoneCodeInput.value = "";
    confirmationResult = null;
    showLoginOptions();
  });

  els.phoneForm.addEventListener("submit", async (event) => {
    event.preventDefault();
    const raw = els.phoneInput.value.trim();
    // Normaliza a E.164: conserva el + inicial (si lo hay) y solo dígitos.
    const phone = (raw.startsWith("+") ? "+" : "") + raw.replace(/\D/g, "");
    if (phone.replace("+", "").length < 8) {
      showGate("Escribe un número de teléfono válido, con indicativo de país (ej. +57...).", true);
      return;
    }
    els.phoneSendBtn.disabled = true;
    els.phoneSendBtn.textContent = "Enviando…";
    try {
      confirmationResult = await sendPhoneCode(phone, "radar-recaptcha-container");
      els.phoneCodeGroup.hidden = false;
      els.phoneCodeInput.focus();
      showGate("Código enviado — revisa tus mensajes SMS.");
    } catch (err) {
      console.error("Error enviando código SMS:", err);
      showGate(`No se pudo enviar el código (${err?.code || "error desconocido"}).`, true);
    } finally {
      els.phoneSendBtn.disabled = false;
      els.phoneSendBtn.textContent = "Enviar código";
    }
  });

  els.phoneVerifyBtn.addEventListener("click", async () => {
    const code = els.phoneCodeInput.value.trim();
    if (!confirmationResult || code.length < 6) {
      showGate("Escribe el código de 6 dígitos que recibiste por SMS.", true);
      return;
    }
    els.phoneVerifyBtn.disabled = true;
    els.phoneVerifyBtn.textContent = "Verificando…";
    try {
      await confirmPhoneCode(confirmationResult, code);
      // Éxito: watchSession() detecta la nueva sesión y oculta el gate.
    } catch (err) {
      console.error("Error verificando código:", err);
      showGate(`Código incorrecto o vencido (${err?.code || "error desconocido"}). Intenta de nuevo.`, true);
    } finally {
      els.phoneVerifyBtn.disabled = false;
      els.phoneVerifyBtn.textContent = "Verificar código";
    }
  });

  // Al volver de Google tras signInWithRedirect, resuelve o revela el error
  // real (dominio no autorizado, popup/redirect bloqueado, etc.) en vez de
  // dejar la pantalla de login sin explicación.
  consumeRedirectResult().catch((err) => {
    console.error("Error procesando el resultado del login:", err);
    showGate(`No se pudo completar el inicio de sesión (${err?.code || "error desconocido"}).`, true);
    els.loginBtn.hidden = false;
  });

  // Validador de estado de sesión: única fuente de verdad de si el gate de
  // login se muestra u oculta. Se dispara con cada cambio de sesión (login,
  // logout, restauración de sesión persistida al recargar la página) para
  // que los avisos de "inicia sesión" desaparezcan en cuanto haya una sesión
  // real y autorizada, y solo entonces.
  function validateSessionAndRender(user, allowed) {
    if (allowed) {
      els.gate.hidden = true;
      els.content.hidden = false;
      els.logoutBtn.hidden = false;
      els.logoutBtn.title = `Sesión: ${user.email || user.phoneNumber}`;
      if (!unsubscribeRadar) unsubscribeRadar = subscribeRadar();
      return;
    }

    if (unsubscribeRadar) {
      unsubscribeRadar();
      unsubscribeRadar = null;
      radar = null;
      settingsHydrated = false;
      clearRefreshTimers();
    }

    // Reinicia el formulario de teléfono al volver a la pantalla de login
    // (evita quedar con un código vencido tras un fallo o cierre de sesión).
    els.phoneForm.hidden = true;
    els.phoneCodeGroup.hidden = true;
    els.showGoogleBtn.hidden = true;
    confirmationResult = null;

    if (user?.email) {
      // Sesión válida de Google, pero no es la cuenta autorizada.
      showGate(`La cuenta ${user.email} no tiene acceso a esta sección.`, true);
      els.loginBtn.textContent = "Entrar con otra cuenta";
    } else if (user?.phoneNumber) {
      showGate(`El número ${user.phoneNumber} no tiene acceso a esta sección.`, true);
      els.loginBtn.textContent = "Iniciar sesión con Google";
    } else {
      showGate("Esta sección es privada. Inicia sesión para ver el radar.");
      els.loginBtn.textContent = "Iniciar sesión con Google";
    }
    showLoginOptions();
  }

  // Aplica el estado ya disponible de inmediato (si el navegador restauró una
  // sesión persistida antes de que este script corriera) y sigue validando
  // ante cualquier cambio posterior.
  if (auth.currentUser) validateSessionAndRender(auth.currentUser, isAllowed(auth.currentUser));
  watchSession(validateSessionAndRender);
</script>
